# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=pass
POSTGRES_DB=postgres_db
DATABASE_URL=postgresql+asyncpg://admin:pass@db:5432/postgres_db

# JWT (openssl rand -hex 32)
JWT_SECRET=your_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Booru API Keys (optional)
DANBOORU_LOGIN=
DANBOORU_API_KEY=
E621_LOGIN=
E621_API_KEY=
RULE34_API_KEY=
RULE34_USER_ID=

# App
APP_PORT=8080

