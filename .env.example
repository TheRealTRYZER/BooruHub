# Database
ENVIRONMENT=development
POSTGRES_USER=booruhub
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=booruhub
DATABASE_URL=postgresql+asyncpg://booruhub:change-me-db-password@db:5432/booruhub

# JWT (openssl rand -hex 32)
JWT_SECRET=replace-with-a-random-64-char-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Encryption (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=replace-with-a-generated-fernet-key
ENCRYPTION_KEY_FALLBACKS=

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Booru API Keys (optional)
DANBOORU_LOGIN=
DANBOORU_API_KEY=
E621_LOGIN=
E621_API_KEY=
RULE34_API_KEY=
RULE34_USER_ID=

# App
APP_PORT=8080

